DATA_DIR=D:/shaun/projects/doc_chatbot/data
DB_BACKEND=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doc_chatbot
PGVECTOR_DIM=1536
PG_CONNECT_TIMEOUT_SEC=5
SQLITE_DB_PATH=D:/shaun/projects/doc_chatbot/data/db/app.db

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_ROUTER_MODEL=gpt-4o-mini
DEFAULT_TENANT_ID=default
INTERNAL_EMAIL_DOMAINS=

MAX_CONTEXT_CHARS=16000
TOP_K=6
RETRIEVAL_MODE=hybrid

ENABLE_RERANKER=true
RERANK_MODEL_ID=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_DEVICE=auto
RERANK_TOP_N=36
INGEST_MAX_WORKERS=2
INGEST_PROGRESS_MIN_INTERVAL_SEC=0.75
INGEST_PROGRESS_MIN_DELTA=3

ENABLE_AI_INGEST_SUMMARIES=false
# Master OCR switch for both tesseract and paddle engines.
ENABLE_OCR=true
OCR_ENGINE=tesseract
PADDLE_OCR_LANG=en
PADDLE_OCR_USE_GPU=false
PADDLE_OCR_MIN_CONFIDENCE=0.50
PADDLE_OCR_MAX_RETRIES=0
PADDLE_OCR_REINIT_ON_FAILURE=false
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
# Set OCR_TESSERACT_CMD when the tesseract executable is not on PATH.
OCR_TESSERACT_CMD=
OCR_TESSERACT_LANG=eng
OCR_TESSERACT_OEM=1
OCR_TESSERACT_PSM=3
OCR_WORKER_TIMEOUT_SEC=60
OCR_WORKER_STARTUP_TIMEOUT_SEC=120
OCR_NATIVE_TEXT_MIN_CHARS=1
OCR_MAX_IMAGE_SIDE=2200
OCR_DIAGRAM_CROP_MAX_SIDE=800
PDF_RENDER_DPI=220
PDF_RENDER_MODE=needed
ENABLE_PPTX_SLIDE_RENDER=true
PPTX_SLIDE_RENDER_POLICY=auto
PPTX_MIN_TEXT_CHARS_FOR_SKIP_RENDER=160
ENABLE_PPTX_RELATIONSHIP_GRAPH=true
PPTX_GRAPH_MAX_EDGES=120
ENABLE_DIAGRAM_PIPELINE=true
DIAGRAM_PARSE_POLICY=auto
DIAGRAM_MAX_IMAGES_PER_DOC=12
ENABLE_YOLO_DIAGRAM_DETECTOR=true
YOLO_MODEL=yolo26n.pt
YOLO_DEVICE=auto
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
YOLO_IMAGE_SIZE=960
DIAGRAM_MIN_NODE_AREA=1600
DIAGRAM_NODE_OCR_TOP_K=12
DIAGRAM_NODE_OCR_MIN_AREA=2400
DIAGRAM_NODE_OCR_MIN_SCORE=0.30
DIAGRAM_MIN_EDGE_LENGTH=48
DIAGRAM_MAX_NODES=80
DIAGRAM_MAX_EDGES=180
DIAGRAM_MAX_NODE_CHUNKS=24
DIAGRAM_MAX_EDGE_CHUNKS=24
DIAGRAM_AUX_CHUNK_LIMIT_PER_PAGE=16
DIAGRAM_AUX_CHUNK_GLOBAL_LIMIT=96
DIAGRAM_TOP_K_FLOOR=14
DIAGRAM_PER_DOC_LIMIT_FLOOR=4
DIAGRAM_MIN_EVIDENCE_SOURCE_TYPES=3
DIAGRAM_MIN_GRAPH_CHUNKS=1
DIAGRAM_MIN_OCR_CHUNKS=2
DIAGRAM_MIN_NODE_CHUNKS=2
DIAGRAM_MIN_EDGE_CHUNKS=2
DIAGRAM_MIN_SLIDE_GRAPH_CHUNKS=0
DIAGRAM_MIXED_EVIDENCE_LIMIT=72
CHUNK_DEDUP_ENABLED=true
CHUNK_DEDUP_MIN_CHARS=40
OPENAI_EMBED_BATCH_SIZE=96
LOCAL_EMBED_BATCH_SIZE=64
