OCR_WORKER_STARTUP_TIMEOUT_SEC=120
OCR_NATIVE_TEXT_MIN_CHARS=1
PDF_RENDER_DPI=220
ENABLE_PPTX_SLIDE_RENDER=true
ENABLE_PPTX_RELATIONSHIP_GRAPH=true
